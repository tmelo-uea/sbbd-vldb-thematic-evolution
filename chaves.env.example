# Copy this file to `chaves.env` and fill in your own API keys.
# `chaves.env` is git-ignored and must never be committed.

# Anthropic API key — used by refine_topics.py for LLM-assisted topic labelling.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# Semantic Scholar API key — used by fetch_semantic_scholar.py.
# Optional, but raises the rate limit. Request one at
# https://www.semanticscholar.org/product/api
S2_API_KEY=your-semantic-scholar-key-here
